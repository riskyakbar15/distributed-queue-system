# ================================
# Konfigurasi Aplikasi
# ================================
# Port instance backend (di-override oleh ecosystem.config.js untuk tiap instance)
PORT=3001
# Nama instance (di-override oleh PM2: app1 / app2 / app3)
INSTANCE_NAME=app1
NODE_ENV=development

# ================================
# Database PostgreSQL (bersama untuk semua instance)
# ================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=queue_db
DB_USER=postgres
DB_PASSWORD=postgres

# ================================
# Redis (bersama untuk semua instance)
# ================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# Session
# ================================
SESSION_SECRET=ubah-nilai-ini-menjadi-rahasia-yang-kuat
