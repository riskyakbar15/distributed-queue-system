{
  "name": "distributed-queue-system",
  "version": "1.0.0",
  "description": "Sistem Antrean Layanan Kampus Terdistribusi menggunakan Node.js, Express, PostgreSQL, Redis, PM2, dan Nginx",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "node scripts/initDb.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "loadtest": "node scripts/loadtest.js",
    "test": "node --test"
  },
  "keywords": [
    "distributed-system",
    "queue",
    "load-balancing",
    "express",
    "redis",
    "postgresql",
    "pm2",
    "nginx"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "connect-redis": "^7.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5"
  }
}
